{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.somfyprotect.integration",
  "version": "1.1.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "brandColor": "#C2410C",
  "name": {
    "en": "Somfy Protect Integration"
  },
  "description": {
    "en": "Smart protection at home with Somfy alarm control and live security status in Homey."
  },
  "author": {
    "name": "Senne"
  },
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "category": [
    "security"
  ],
  "settings": [
    {
      "id": "somfy_username",
      "type": "text",
      "title": {
        "en": "Somfy Username"
      },
      "hint": {
        "en": "Email used for Somfy Protect login"
      },
      "value": ""
    },
    {
      "id": "somfy_password",
      "type": "password",
      "title": {
        "en": "Somfy Password"
      },
      "value": ""
    },
    {
      "id": "somfy_poll_interval",
      "type": "number",
      "title": {
        "en": "Polling Interval"
      },
      "hint": {
        "en": "Seconds between Somfy sync cycles"
      },
      "units": {
        "en": "seconds"
      },
      "value": 5,
      "min": 5,
      "max": 300,
      "step": 1
    },
    {
      "id": "somfy_enabled",
      "type": "checkbox",
      "title": {
        "en": "Enable Somfy Sync"
      },
      "hint": {
        "en": "Enable/disable polling from Somfy Protect"
      },
      "value": false
    }
  ],
  "permissions": [],
  "api": {
    "getHealth": {
      "method": "GET",
      "path": "/health"
    },
    "getStatus": {
      "method": "GET",
      "path": "/status"
    },
    "getDiscoveredDevices": {
      "method": "GET",
      "path": "/devices"
    },
    "saveCredentials": {
      "method": "POST",
      "path": "/credentials"
    },
    "clearCredentials": {
      "method": "DELETE",
      "path": "/credentials"
    },
    "setEnabled": {
      "method": "POST",
      "path": "/sync/enabled"
    },
    "syncNow": {
      "method": "POST",
      "path": "/sync/once"
    },
    "setSiteState": {
      "method": "POST",
      "path": "/site/:id/state"
    }
  },
  "drivers": [
    {
      "name": {
        "en": "Somfy IntelliTag"
      },
      "images": {
        "small": "/drivers/intellitag/assets/images/small.png",
        "large": "/drivers/intellitag/assets/images/large.png"
      },
      "class": "sensor",
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "energy": {
        "batteries": [
          "OTHER"
        ]
      },
      "capabilities": [
        "alarm_contact",
        "alarm_tamper",
        "measure_battery"
      ],
      "pair": [
