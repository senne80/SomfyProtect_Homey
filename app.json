          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "title": {
              "en": "Sign in to Somfy Protect"
            },
            "usernameLabel": {
              "en": "Somfy Username"
            },
            "usernamePlaceholder": {
              "en": "name@example.com"
